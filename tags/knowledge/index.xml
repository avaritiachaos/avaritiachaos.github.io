onerror="this.style.display='none'"&gt;
&lt;picture&gt;
&lt;source data-srcset="https://cdn.jsdelivr.net/gh/avaritiachaos/shark-img/webp/image-20230408181443345.webp" type="image/webp"&gt;
&lt;img data-src="https://cdn.jsdelivr.net/gh/avaritiachaos/shark-img/image-20230408181443345.png"
